{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npx prisma generate && node node_modules/typescript/bin/tsc",
  "outputDirectory": ".",
  "functions": {
    "api/index.ts": {
      "includeFiles": "prisma/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    }
  ]
}
