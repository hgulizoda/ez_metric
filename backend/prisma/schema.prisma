generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int           @id @default(autoincrement())
  username        String        @unique
  password_hash   String
  role            UserRole
  created_at      DateTime      @default(now())
  status_changes  ClockRecord[]

  @@map("users")
}

model Worker {
  id            Int           @id @default(autoincrement())
  base_id       String        @unique
  name          String
  salary_type   SalaryType
  language      String
  picture_url   String?
  resume_url    String?
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  position      String
  bonuses       Bonus[]
  charges       Charge[]
  clock_records ClockRecord[]
  salary_rules  SalaryRule[]
  worker_shifts WorkerShift[]

  @@map("workers")
}

model Shift {
  id            Int           @id @default(autoincrement())
  name          String
  start_time    DateTime
  end_time      DateTime
  status        ShiftStatus   @default(active)
  created_at    DateTime      @default(now())
  clock_records ClockRecord[]
  worker_shifts WorkerShift[]

  @@map("shifts")
}

model WorkerShift {
  id        Int               @id @default(autoincrement())
  worker_id Int
  shift_id  Int
  date      DateTime          @db.Date
  status    WorkerShiftStatus @default(scheduled)
  shift     Shift             @relation(fields: [shift_id], references: [id], onDelete: Cascade)
  worker    Worker            @relation(fields: [worker_id], references: [id], onDelete: Cascade)

  @@map("worker_shifts")
}

model ClockRecord {
  id                   Int          @id @default(autoincrement())
  worker_id            Int
  shift_id             Int
  device_id            Int?
  shift_type_id        Int?
  clock_in             DateTime
  clock_out            DateTime?
  status               ClockStatus  @default(pending)
  status_changed_by    Int?
  status_changed_at    DateTime?
  status_note          String?
  is_manual_edit       Boolean      @default(false)
  edit_note            String?
  grace_period_applied Boolean      @default(false)
  created_at           DateTime     @default(now())
  shift                Shift        @relation(fields: [shift_id], references: [id], onDelete: Cascade)
  worker               Worker       @relation(fields: [worker_id], references: [id], onDelete: Cascade)
  device               Device?      @relation(fields: [device_id], references: [id], onDelete: SetNull)
  shift_type           ShiftType?   @relation(fields: [shift_type_id], references: [id], onDelete: SetNull)
  status_changed       User?        @relation(fields: [status_changed_by], references: [id], onDelete: SetNull)

  @@map("clock_records")
}

model GracePeriodRule {
  id              Int      @id @default(autoincrement())
  name            String
  minutes_allowed Int
  created_at      DateTime @default(now())

  @@map("grace_period_rules")
}

model SalaryRule {
  id                       Int        @id @default(autoincrement())
  worker_id                Int
  type                     SalaryType
  rate                     Decimal    @db.Decimal(10, 2)
  overtime_multiplier      Decimal    @default(1.5) @db.Decimal(4, 2)
  overtime_threshold_hours Int        @default(40)
  created_at               DateTime   @default(now())
  worker                   Worker     @relation(fields: [worker_id], references: [id], onDelete: Cascade)

  @@map("salary_rules")
}

model Charge {
  id                       Int        @id @default(autoincrement())
  worker_id                Int
  type                     ChargeType
  amount                   Decimal    @db.Decimal(10, 2)
  remaining                Decimal    @db.Decimal(10, 2)
  distributed_over_periods Int?
  description              String
  created_at               DateTime   @default(now())
  updated_at               DateTime   @updatedAt
  worker                   Worker     @relation(fields: [worker_id], references: [id], onDelete: Cascade)

  @@map("charges")
}

model BonusRule {
  id                       Int      @id @default(autoincrement())
  position                 String
  formula                  String
  min_efficiency_threshold Decimal  @db.Decimal(5, 2)
  created_at               DateTime @default(now())

  @@map("bonus_rules")
}

model Bonus {
  id         Int       @id @default(autoincrement())
  worker_id  Int
  amount     Decimal   @db.Decimal(10, 2)
  type       BonusType
  period     DateTime  @db.Date
  note       String?
  created_at DateTime  @default(now())
  worker     Worker    @relation(fields: [worker_id], references: [id], onDelete: Cascade)

  @@map("bonuses")
}

enum UserRole {
  admin
  manager
}

enum SalaryType {
  hourly
  percentage
  flat
}

enum ShiftStatus {
  active
  completed
  missed
}

enum WorkerShiftStatus {
  scheduled
  completed
  missed
  late
}

enum ChargeType {
  loan
  prepayment
  distribution
  time_misuse
}

enum BonusType {
  formula
  manual
}

enum ClockStatus {
  pending
  approved
  rejected
  flagged
}

model Department {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  code       String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("departments")
}

model ShiftType {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  clock_records ClockRecord[]

  @@map("shift_types")
}

model Device {
  id            Int           @id @default(autoincrement())
  name          String
  serial_number String?       @unique
  location      String?
  is_active     Boolean       @default(true)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  clock_records ClockRecord[]

  @@map("devices")
}

model Job {
  id         Int      @id @default(autoincrement())
  title      String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("jobs")
}
